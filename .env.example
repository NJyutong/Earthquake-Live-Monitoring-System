# Copy this file to .env and fill only the services you intend to use.
# Never commit .env. Empty values intentionally disable the related integration.

# Server
HOST=127.0.0.1
PORT=3000
# Use the public HTTPS origin in production, without a trailing slash.
PUBLIC_ORIGIN=http://127.0.0.1:3000

# Protected debug tools (required for production; 8-128 characters with
# uppercase, number, and symbol). There is no default administrator password.
DEBUG_PASSWORD=

# Maps
AMAP_JS_KEY=
AMAP_SECURITY_JSCODE=
YANDEX_MAPS_API_KEY=
YANDEX_DAILY_LIMIT=100
GOOGLE_MAPS_API_KEY=
TIANDITU_TK=
ESRI_API_KEY=

# Earthquake feeds and optional history webhook
CWA_API_KEY=
CHINA_HISTORY_HOOK_URLS=

# Web Push. Set both VAPID keys or leave both empty so a local key pair is
# generated under data/ on first use. Persist data/ outside ephemeral containers.
VAPID_SUBJECT=mailto:admin@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
PUSH_SEND_TIMEOUT_MS=10000
MAX_PUSH_SUBSCRIPTIONS=10000

# Optional outbound push transport. Configure at most one mode.
PUSH_PROXY_URL=
PUSH_RELAY_URL=
PUSH_RELAY_SECRET=

# Reverse proxy and TLS (optional)
TRUST_PROXY=
TRUST_GEO_HEADERS=false
TLS_KEY_PATH=
TLS_CERT_PATH=
HTTP_MAX_HEADER_SIZE=32768
WS_MAX_CONNECTIONS=512
SERVER_MAX_CONNECTIONS=1024

